/*
 * Devicetree overlay for nRF52840 Dongle — Cervos Meeting Bridge
 * USB Audio Class. NVS uses the board's built-in storage_partition.
 */

&zephyr_udc0 {
	status = "okay";

	hp_0 {
		compatible = "usb-audio-hp";
		feature-mute;
		channel-l;
		channel-r;
		resolution = <16>;
		sample-rate-hz = <48000>;

		feature-volume;
		volume-max = <0x0500>;
		volume-min = <0xBA00>;
		volume-res = <0x100>;
	};
	mic_0 {
		compatible = "usb-audio-mic";
		feature-mute;
		channel-l;
		channel-r;
		resolution = <16>;
		sample-rate-hz = <48000>;
	};
};
