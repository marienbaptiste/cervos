/*
 * Devicetree overlay for nRF52840 Dongle — "cervhole headset"
 * USB Audio Class with headphones + microphone (Windows requires both).
 */

&zephyr_udc0 {
	status = "okay";

	hp_0 {
		compatible = "usb-audio-hp";
		feature-mute;
		channel-l;
		channel-r;

		feature-volume;
		volume-max = <0x0500>;
		volume-min = <0xBA00>;
		volume-res = <0x100>;
	};
	mic_0 {
		compatible = "usb-audio-mic";
		feature-mute;
		channel-l;
		channel-r;
	};
};
